# ─── Supabase ───────────────────────────────────────────────────
# Vai a https://supabase.com → New Project → Settings → API
SUPABASE_URL=https://XXXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── JWT ────────────────────────────────────────────────────────
# Gera uma string aleatória longa: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=muda_isto_para_uma_string_secreta_muito_longa

# ─── Servidor ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Frontend (para CORS) ───────────────────────────────────────
FRONTEND_URL=http://localhost:5173
